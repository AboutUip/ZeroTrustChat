{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-base",
      "hidden": true,
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build"
    },
    {
      "name": "windows-exe-only",
      "displayName": "ZChatIM — console EXE only",
      "description": "ZChatIM.exe + ZChatIMCore.lib; no JNI DLL. OpenSSL/SQLCipher per CMakeLists.",
      "inherits": "windows-base",
      "cacheVariables": {
        "ZCHATIM_BUILD_MODE": "ExeOnly"
      }
    },
    {
      "name": "windows-jni-dll-only",
      "displayName": "ZChatIM — JNI DLL only",
      "description": "ZChatIMJNI.dll + ZChatIMCore.lib; no console EXE. Set JAVA_HOME for jni.h.",
      "inherits": "windows-base",
      "cacheVariables": {
        "ZCHATIM_BUILD_MODE": "JniDllOnly"
      }
    },
    {
      "name": "windows-both",
      "displayName": "ZChatIM — EXE + JNI DLL",
      "description": "ZChatIM.exe and ZChatIMJNI.dll.",
      "inherits": "windows-base",
      "cacheVariables": {
        "ZCHATIM_BUILD_MODE": "Both"
      }
    }
  ]
}
