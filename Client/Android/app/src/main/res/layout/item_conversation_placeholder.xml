<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:minHeight="56dp"
    android:orientation="horizontal"
    android:paddingHorizontal="@dimen/main_content_padding_horizontal"
    android:paddingVertical="10dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="@dimen/contact_row_avatar_size"
        android:layout_height="@dimen/contact_row_avatar_size"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeColor="?attr/colorOutlineVariant"
        app:strokeWidth="1dp">

        <ImageView
            android:id="@+id/conversationAvatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/colorSurfaceVariant"
            android:contentDescription="@string/profile_card_avatar"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_avatar_default" />
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/conversationTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp"
            tools:text="Name" />

        <TextView
            android:id="@+id/conversationSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="13sp"
            tools:text="Last message preview" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:gravity="end"
        android:orientation="vertical">

        <TextView
            android:id="@+id/conversationTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="12sp"
            tools:text="12:30" />

        <TextView
            android:id="@+id/conversationUnread"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_conversation_unread_badge"
            android:backgroundTint="?attr/colorPrimary"
            android:gravity="center"
            android:minWidth="20dp"
            android:minHeight="20dp"
            android:paddingHorizontal="6dp"
            android:textColor="?attr/colorOnPrimary"
            android:textSize="11sp"
            android:visibility="gone"
            tools:text="3"
            tools:visibility="visible" />
    </LinearLayout>
</LinearLayout>
