<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/chatToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="?attr/colorOnSurface" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingHorizontal="@dimen/main_content_padding_horizontal"
        android:paddingTop="8dp"
        android:paddingBottom="8dp" />

    <LinearLayout
        android:id="@+id/chatReplyBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurfaceContainer"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="6dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/chatReplyBarText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="13sp" />

        <ImageButton
            android:id="@+id/chatReplyBarDismiss"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/chat_reply_cancel"
            android:padding="8dp"
            android:src="@drawable/ic_close_small"
            app:tint="?attr/colorOnSurfaceVariant" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/chatInputBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/chat_input_bar_bg"
        android:gravity="bottom"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingTop="6dp"
        android:paddingEnd="8dp"
        android:paddingBottom="6dp">

        <ImageButton
            android:id="@+id/chatEmojiToggle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/chat_emoji_toggle"
            android:padding="10dp"
            android:src="@drawable/ic_chat_emoji"
            app:tint="?attr/colorOnSurfaceVariant" />

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            android:layout_weight="1"
            android:minHeight="44dp">

            <EditText
                android:id="@+id/chatInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chat_input_field"
                android:hint="@string/chat_input_hint"
                android:imeOptions="actionSend"
                android:importantForAutofill="no"
                android:inputType="textCapSentences|textMultiLine"
                android:maxLines="6"
                android:minHeight="44dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="?attr/colorOnSurfaceVariant"
                android:textSize="16sp" />
        </FrameLayout>

        <ImageButton
            android:id="@+id/chatVoiceCall"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/voice_call_menu"
            android:padding="10dp"
            android:src="@drawable/ic_chat_voice"
            app:tint="?attr/colorPrimary" />

        <ImageButton
            android:id="@+id/chatSend"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_chat_send_circle"
            android:contentDescription="@string/chat_send"
            android:padding="10dp"
            android:src="@drawable/ic_chat_send"
            app:tint="?attr/colorOnPrimary" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatEmojiPanel"
        android:layout_width="match_parent"
        android:layout_height="@dimen/chat_emoji_panel_height"
        android:background="?attr/colorSurfaceContainer"
        android:clipToPadding="false"
        android:paddingHorizontal="4dp"
        android:paddingVertical="8dp"
        android:visibility="gone"
        tools:listitem="@layout/item_chat_emoji_cell" />
</LinearLayout>
