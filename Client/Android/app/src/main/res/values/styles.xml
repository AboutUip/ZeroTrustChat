        <item name="android:minHeight">@dimen/bottom_nav_min_height</item>
        <item name="itemIconSize">@dimen/bottom_nav_icon_size</item>
        <item name="itemPaddingTop">0dp</item>
        <item name="itemPaddingBottom">0dp</item>
        <item name="itemTextAppearanceActive">@style/TextAppearance.ZChat.BottomNav.Label</item>
